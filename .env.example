# ============================================
# ms-blockchain - Variables de Entorno
# ============================================

# --- App ---
SERVER_PORT=3001
NODE_ENV=production

# --- Base de datos ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=bustrack_blockchain
DB_USER=bustrack
DB_PASSWORD=bustrack123

# --- JWT (misma secret que MS-Core para validar tokens) ---
JWT_SECRET=cambia-esta-clave-secreta

# --- Blockchain ---
# false = usa la red real de Polygon Mumbai
# true  = mock local sin transacciones reales (solo desarrollo)
MOCK_BLOCKCHAIN=false
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
WALLET_PRIVATE_KEY=0xtu_clave_privada_aqui
CONTRACT_ADDRESS=0xdireccion_del_contrato_desplegado

# Ajustes de gas (Mumbai)
GAS_LIMIT=200000
GAS_PRICE_GWEI=30

# --- MS-Core ---
MS_CORE_URL=http://localhost:3000

# --- Docker (solo produccion) ---
# DOCKER_REGISTRY=ms-blockchain
# IMAGE_TAG=latest
